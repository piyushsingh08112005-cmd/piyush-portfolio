   "source": [
    "#include <stdio.h>\n",
    "\n",
    "int main(void) {\n",
    "    int arr[] = {2, 4, 6, 8, 10};\n",
    "    int sum = 0;\n",
    "    for (int i = 0; i < 5; i++) sum += arr[i];\n",
    "    printf(\"Sum = %d\\n\", sum);\n",
    "    return 0;\n",
    "}"
   ]
  }
