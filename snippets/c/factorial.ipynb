    "# Factorial\n",
    "\n",
    "**Language:** C\n",
    "\n",
    "**Level:** advanced"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "a7668b89",
   "metadata": {},
   "outputs": [],
   "source": [
    "#include <stdio.h>\n",
    "\n",
    "long long factorial(int n) {\n",
    "    return (n <= 1) ? 1 : (long long)n * factorial(n - 1);\n",
    "}\n",
    "\n",
    "int main(void) {\n",
    "    int n = 5;\n",
    "    printf(\"Factorial of %d = %lld\\n\", n, factorial(n));\n",
    "    return 0;\n",
    "}"
   ]
  }
